# Selah environment variable names. Never commit real values.
# None are required for local fixture rendering. The production Studio launch
# path requires Supabase, OpenAI, the Studio key, and the ESV API key below.

# --- Supabase (chapter storage, Studio settings, Brain, and images) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Studio access + signed background jobs ---
DEV_ADMIN_TOKEN=
# Optional dedicated worker-signing key; falls back to DEV_ADMIN_TOKEN.
GENERATION_JOB_SECRET=

# --- Scripture source used during Mark 8 preparation ---
ESV_API_KEY=

# --- OpenAI (private draft and image creation) ---
OPENAI_API_KEY=
# Optional defaults. Studio's saved, approved choices take precedence.
CHAPTER_WORKUP_TEXT_MODEL=
CHAPTER_IMAGE_MODEL=

# --- Legacy dev tools (not required by Studio; leave OFF in production) ---
ENABLE_DEV_ROUTES=false
REGEN_TOKEN=

# --- Dogfood switch: render the generated fixture as the real chapter source ---
# Default ON. Set to "false" to render the hand-authored workup instead.
NEXT_PUBLIC_USE_GENERATED_FIXTURE=true
