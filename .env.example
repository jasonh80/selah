# Selah environment variables.
# NONE of these are required for local rendering — the app falls back to the
# local fixture/registry when Supabase and OpenAI are not configured.

# --- Supabase (storage layer; optional until we persist generated workups) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (not wired yet) ---
OPENAI_API_KEY=

# --- Dogfood switch: render the generated fixture as the real chapter source ---
# Default ON. Set to "false" to render the hand-authored workup instead.
NEXT_PUBLIC_USE_GENERATED_FIXTURE=true
