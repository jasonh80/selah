    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "verify:brain": "node --import tsx scripts/verify-selah-brain.ts",
    "verify:authoring": "node --import tsx scripts/verify-mark-authoring-contract.ts",
    "verify:manifest": "node --import tsx scripts/verify-generation-manifest.ts",
    "verify:source": "node --import tsx scripts/verify-mark-sprint-esv-source.ts",
    "verify:manifest-v3": "node --import tsx scripts/verify-generation-manifest-v3.ts",
    "verify:mark-runtime": "node --import tsx scripts/verify-mark-sprint-runtime.ts",
    "verify:mark-draft": "node --import tsx scripts/verify-mark-sprint-draft-pipeline.ts",
    "verify:mark-worker": "node --import tsx scripts/verify-mark-sprint-draft-job.ts",
    "verify:benchmark": "node --import tsx scripts/verify-selah-benchmark-review.ts",
    "validate:workup": "node --import tsx scripts/validate-workup.ts",
    "check:workup": "npm run validate:workup",
    "verify:supabase": "tsx scripts/verify-supabase-workups.ts",
    "verify:studio-safety": "node --import tsx scripts/verify-studio-safety.ts",
    "verify:studio-mark8-preflight": "node --import tsx scripts/verify-studio-mark8-preflight.ts",
    "verify:studio-preview-access": "node --import tsx scripts/verify-studio-preview-access.ts",
    "verify:studio-polish": "node --import tsx scripts/verify-studio-polish.ts",
    "verify:esv-attribution": "node --import tsx scripts/verify-esv-attribution.ts",
    "verify:diagnostics-display": "node --import tsx scripts/verify-overlap-diagnostics-display.ts",
    "verify:maps-honesty": "node --import tsx scripts/verify-maps-honesty.ts",
    "verify:image-redo": "node --import tsx scripts/verify-image-redo.ts",
    "verify:today": "node --import tsx scripts/verify-today-resolution.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.45.4",
    "maplibre-gl": "4.7.1",
    "next": "14.2.5",
    "openai": "4.67.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "tsx": "4.19.1",
    "typescript": "5.5.3"
  }
